# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Project Settings > API > Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Found in: Project Settings > API > service_role (secret) key
# WARNING: Never expose this in a frontend. Server-only.
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── API Security ─────────────────────────────────────────────────────────────
# Secret shared by all trusted callers sending write requests
API_KEY=change-me-to-a-long-random-string

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
